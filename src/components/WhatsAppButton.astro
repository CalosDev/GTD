---
import type { ContactSettings } from "../types/contact";

interface Props {
  contactSettings: ContactSettings;
}

const { contactSettings } = Astro.props;
const whatsappUrl = contactSettings.whatsappUrl;
---

{
  whatsappUrl && (
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
      class="fixed bottom-5 right-5 z-50 flex h-12 w-12 items-center justify-center rounded-lg border border-white/[0.08] bg-[#00e0c7] text-base font-black text-black shadow-lg shadow-black/30 transition hover:-translate-y-1 hover:bg-[#00b89f]"
    >
      <svg
        viewBox="0 0 24 24"
        aria-hidden="true"
        class="h-6 w-6 fill-current"
      >
        <path d="M12 2a9.5 9.5 0 0 0-8.3 14.2L3 22l5-1.1A9.5 9.5 0 1 0 12 2Zm0 17.3c-1.4 0-2.8-.4-4-1.1l-.3-.2-3 .7.7-2.9-.2-.3A7.3 7.3 0 1 1 12 19.3Zm4.2-5.5c-.2-.1-1.4-.7-1.6-.8-.2-.1-.4-.1-.6.1-.2.2-.7.8-.9 1-.2.2-.3.2-.6.1-.3-.1-1.1-.4-2-1.3-.7-.6-1.2-1.4-1.3-1.7-.1-.3 0-.5.1-.6l.4-.5c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5l-.8-1.9c-.2-.4-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.2.2-.8.8-.8 2 0 1.2.9 2.3 1.1 2.6.1.2 1.8 2.8 4.4 3.9.6.3 1 .5 1.4.6.6.2 1.2.2 1.6.1.5-.1 1.4-.6 1.6-1.2.2-.6.2-1.1.1-1.2-.1-.1-.3-.2-.6-.3Z" />
      </svg>
    </a>
  )
}
