---
import type { AudiovisualContent } from "../types/content";
import { formatContentDate } from "../lib/dates";

interface Props {
  item: AudiovisualContent;
}

const { item } = Astro.props;
---

<article class="group overflow-hidden rounded-lg border border-white/[0.08] bg-[#101315] media-lift">
  <a href={`/contenido/${item.slug}`} class="focus-ring block rounded-lg" aria-label={`Ver contenido: ${item.title}`}>
    <div class="relative aspect-[4/3] overflow-hidden bg-zinc-950">
      <img
        src={item.image}
        alt={item.title}
        loading="lazy"
        decoding="async"
        width="600"
        height="450"
        class="h-full w-full object-cover opacity-100 transition duration-700 group-hover:scale-105"
      />

      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>

      <div class="absolute left-3 top-3 flex flex-wrap gap-2">
        <span class="rounded-md border border-white/10 bg-black/70 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] text-white backdrop-blur">
          {item.type === "video" ? "Video" : "Foto"}
        </span>

        {
          item.featured && (
            <span class="rounded-md bg-[#00e0c7] px-3 py-1 text-[11px] font-black uppercase tracking-[0.14em] text-black">
              Destacado
            </span>
          )
        }
      </div>

      <div class="absolute bottom-4 left-4 right-4">
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#00e0c7]">
          {item.category}
        </p>

        <h3 class="mt-2 line-clamp-2 text-xl font-black leading-tight text-white">
          {item.title}
        </h3>
      </div>
    </div>

    <div class="p-5">
      <p class="line-clamp-2 min-h-12 text-sm leading-6 text-zinc-400">
        {item.description}
      </p>

      <div class="mt-5 flex items-center justify-between gap-4 border-t border-white/[0.08] pt-4 text-xs text-zinc-500">
        <span class="line-clamp-1">{item.location}</span>
        <span class="shrink-0">{formatContentDate(item.date)}</span>
      </div>
    </div>
  </a>
</article>
