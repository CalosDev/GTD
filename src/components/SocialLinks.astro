---
import type { SocialLink } from "../types/contact";

interface Props {
  links: SocialLink[];
  size?: "sm" | "md";
  showLabels?: boolean;
  showDisabled?: boolean;
}

const { links = [], size = "md", showLabels = false, showDisabled = false } = Astro.props;

const sizeClass =
  size === "sm"
    ? "h-10 w-10 rounded-lg"
    : "h-12 w-12 rounded-lg";
---

{
  links.length > 0 && (
    <div class={`flex flex-wrap gap-3 ${showLabels ? "items-stretch" : "items-center"}`}>
      {links.map((link) => (
        link.url ? (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class={`social-link focus-ring ${sizeClass} ${showLabels ? "w-auto min-w-32 px-4" : "justify-center"}`}
            aria-label={`Abrir ${link.label}`}
            title={link.label}
          >
            <span class="social-link__icon" aria-hidden="true">
              {
                link.id === "facebook" && (
                  <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current">
                    <path d="M13.5 21v-7h2.4l.4-3h-2.8V9.1c0-.9.3-1.6 1.6-1.6H16V4.8c-.2 0-.9-.1-1.8-.1-2.7 0-4.2 1.6-4.2 4.5V11H7.5v3H10v7h3.5Z"></path>
                  </svg>
                )
              }
              {
                link.id === "instagram" && (
                  <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current">
                    <path d="M7.2 3h9.6A4.2 4.2 0 0 1 21 7.2v9.6a4.2 4.2 0 0 1-4.2 4.2H7.2A4.2 4.2 0 0 1 3 16.8V7.2A4.2 4.2 0 0 1 7.2 3Zm0 1.8A2.4 2.4 0 0 0 4.8 7.2v9.6a2.4 2.4 0 0 0 2.4 2.4h9.6a2.4 2.4 0 0 0 2.4-2.4V7.2a2.4 2.4 0 0 0-2.4-2.4H7.2Zm10 1.3a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2ZM12 7.6A4.4 4.4 0 1 1 7.6 12 4.4 4.4 0 0 1 12 7.6Zm0 1.8A2.6 2.6 0 1 0 14.6 12 2.6 2.6 0 0 0 12 9.4Z"></path>
                  </svg>
                )
              }
              {
                link.id === "youtube" && (
                  <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current">
                    <path d="M21.6 7.2a2.8 2.8 0 0 0-2-2c-1.8-.5-7.6-.5-7.6-.5s-5.8 0-7.6.5a2.8 2.8 0 0 0-2 2A29.2 29.2 0 0 0 2 12a29.2 29.2 0 0 0 .4 4.8 2.8 2.8 0 0 0 2 2c1.8.5 7.6.5 7.6.5s5.8 0 7.6-.5a2.8 2.8 0 0 0 2-2A29.2 29.2 0 0 0 22 12a29.2 29.2 0 0 0-.4-4.8ZM10 15.5v-7l6 3.5-6 3.5Z"></path>
                  </svg>
                )
              }
              {
                link.id === "tiktok" && (
                  <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current">
                    <path d="M14.6 3c.2 1.7 1.2 3.3 2.8 4.1 1 .5 2.1.8 3.2.8v2.9c-1.5 0-3-.4-4.3-1.1v5.1a6 6 0 1 1-5.2-6v3a2.9 2.9 0 1 0 2.2 2.8V3h1.3Z"></path>
                  </svg>
                )
              }
            </span>

            {showLabels && <span class="text-sm font-semibold text-white">{link.label}</span>}
          </a>
        ) : (
          showDisabled && (
            <span
              class={`social-link social-link--disabled ${sizeClass} ${showLabels ? "w-auto min-w-32 px-4" : "justify-center"}`}
              aria-label={`${link.label} no configurado`}
              title={`${link.label} no configurado`}
            >
              <span class="social-link__icon" aria-hidden="true">
                {
                  link.id === "facebook" && (
                    <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current">
                      <path d="M13.5 21v-7h2.4l.4-3h-2.8V9.1c0-.9.3-1.6 1.6-1.6H16V4.8c-.2 0-.9-.1-1.8-.1-2.7 0-4.2 1.6-4.2 4.5V11H7.5v3H10v7h3.5Z"></path>
                    </svg>
                  )
                }
                {
                  link.id === "instagram" && (
                    <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current">
                      <path d="M7.2 3h9.6A4.2 4.2 0 0 1 21 7.2v9.6a4.2 4.2 0 0 1-4.2 4.2H7.2A4.2 4.2 0 0 1 3 16.8V7.2A4.2 4.2 0 0 1 7.2 3Zm0 1.8A2.4 2.4 0 0 0 4.8 7.2v9.6a2.4 2.4 0 0 0 2.4 2.4h9.6a2.4 2.4 0 0 0 2.4-2.4V7.2a2.4 2.4 0 0 0-2.4-2.4H7.2Zm10 1.3a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2ZM12 7.6A4.4 4.4 0 1 1 7.6 12 4.4 4.4 0 0 1 12 7.6Zm0 1.8A2.6 2.6 0 1 0 14.6 12 2.6 2.6 0 0 0 12 9.4Z"></path>
                    </svg>
                  )
                }
                {
                  link.id === "youtube" && (
                    <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current">
                      <path d="M21.6 7.2a2.8 2.8 0 0 0-2-2c-1.8-.5-7.6-.5-7.6-.5s-5.8 0-7.6.5a2.8 2.8 0 0 0-2 2A29.2 29.2 0 0 0 2 12a29.2 29.2 0 0 0 .4 4.8 2.8 2.8 0 0 0 2 2c1.8.5 7.6.5 7.6.5s5.8 0 7.6-.5a2.8 2.8 0 0 0 2-2A29.2 29.2 0 0 0 22 12a29.2 29.2 0 0 0-.4-4.8ZM10 15.5v-7l6 3.5-6 3.5Z"></path>
                    </svg>
                  )
                }
                {
                  link.id === "tiktok" && (
                    <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current">
                      <path d="M14.6 3c.2 1.7 1.2 3.3 2.8 4.1 1 .5 2.1.8 3.2.8v2.9c-1.5 0-3-.4-4.3-1.1v5.1a6 6 0 1 1-5.2-6v3a2.9 2.9 0 1 0 2.2 2.8V3h1.3Z"></path>
                    </svg>
                  )
                }
              </span>

              {showLabels && <span class="text-sm font-semibold text-zinc-500">{link.label}</span>}
            </span>
          )
        )
      ))}
    </div>
  )
}
