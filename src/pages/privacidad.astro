---
import MainLayout from "../layouts/MainLayout.astro";
import { siteConfig } from "../config/site";
import { getPageBySlug } from "../lib/wordpress";

const managedPage = await getPageBySlug("privacidad");
const pageTitle = managedPage?.title || "Politica de privacidad";
const pageExcerpt =
  managedPage?.excerpt || `Politica de privacidad de ${siteConfig.name}.`;
---

<MainLayout
  title={`${pageTitle} - ${siteConfig.name}`}
  description={pageExcerpt}
>
  <main class="bg-[#08090a] px-6 py-16 md:py-20">
    <div class="mx-auto max-w-4xl">
      <p class="section-eyebrow">
        Legal
      </p>

      <h1 class="mt-4 text-4xl font-black text-white md:text-5xl">
        {pageTitle}
      </h1>

      {
        managedPage?.contentHtml ? (
          <div class="mt-10 rounded-lg border border-white/[0.08] bg-[#101315] p-6 md:p-8">
            <div class="rich-content" set:html={managedPage.contentHtml}></div>
          </div>
        ) : (
          <div class="mt-10 space-y-8 rounded-lg border border-white/[0.08] bg-[#101315] p-6 leading-8 text-zinc-400 md:p-8">
            <section>
              <h2 class="text-2xl font-bold text-white">1. Informacion general</h2>
              <p class="mt-3">
                Esta politica explica como {siteConfig.name} puede recopilar, utilizar y
                proteger la informacion relacionada con los visitantes del sitio web.
              </p>
            </section>

            <section>
              <h2 class="text-2xl font-bold text-white">2. Informacion recopilada</h2>
              <p class="mt-3">
                El sitio puede recopilar informacion basica enviada voluntariamente por el usuario
                a traves de formularios, enlaces de contacto, WhatsApp u otros medios disponibles.
              </p>
            </section>

            <section>
              <h2 class="text-2xl font-bold text-white">3. Uso de la informacion</h2>
              <p class="mt-3">
                La informacion puede utilizarse para responder solicitudes, brindar informacion
                sobre contenido audiovisual, mejorar la experiencia del sitio y mantener
                comunicacion con los usuarios interesados.
              </p>
            </section>

            <section>
              <h2 class="text-2xl font-bold text-white">4. Contenido audiovisual</h2>
              <p class="mt-3">
                Las imagenes, videos y publicaciones mostradas en el sitio son utilizadas con
                fines informativos, promocionales o institucionales segun corresponda.
              </p>
            </section>

            <section>
              <h2 class="text-2xl font-bold text-white">5. Contacto externo</h2>
              <p class="mt-3">
                Al hacer clic en enlaces externos como WhatsApp, Facebook, Instagram, YouTube u
                otras plataformas, el usuario estara sujeto a las politicas de privacidad de
                dichas plataformas.
              </p>
            </section>

            <section>
              <h2 class="text-2xl font-bold text-white">6. Cambios en esta politica</h2>
              <p class="mt-3">
                {siteConfig.name} puede actualizar esta politica cuando sea necesario. Los cambios
                seran publicados en esta misma pagina.
              </p>
            </section>
          </div>
        )
      }
    </div>
  </main>
</MainLayout>
