---
import MainLayout from "../layouts/MainLayout.astro";
import { siteConfig } from "../config/site";
---

<MainLayout
  title={`Página no encontrada - ${siteConfig.name}`}
  description="La página que buscas no está disponible."
>
  <main class="bg-[#08090a] px-6">
    <section class="mx-auto flex min-h-[72vh] max-w-4xl flex-col items-center justify-center py-20 text-center">
      <p class="section-eyebrow">
        Error 404
      </p>

      <h1 class="mt-4 text-4xl font-black text-white md:text-6xl">
        Página no encontrada
      </h1>

      <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-400">
        La página que intentas visitar no existe, fue movida o ya no está disponible.
      </p>

      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/" class="btn-main">
          Volver al inicio
        </a>

        <a href="/galeria" class="btn-ghost">
          Ver galería
        </a>
      </div>
    </section>
  </main>
</MainLayout>
